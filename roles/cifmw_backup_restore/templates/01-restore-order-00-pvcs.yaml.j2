---
# Restore Order 00: Storage Foundation - PVCs
apiVersion: velero.io/v1
kind: Restore
metadata:
  name: openstack-restore-00-pvcs-{{ restore_suffix }}
  namespace: {{ cifmw_backup_restore_oadp_namespace }}
spec:
  backupName: {{ pvc_backup_name }}
  includedNamespaces:
  - {{ cifmw_backup_restore_namespace }}
  excludedResources:
  - pods
  resourceModifier:
    kind: ConfigMap
    name: openstack-restore-resource-modifiers
  restorePVs: true
